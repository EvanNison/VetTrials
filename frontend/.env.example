# Copy this file to .env (or .env.local) and fill in real values.
# Never commit .env to git.

# Public URL of the backend API. Leave blank to use same-origin requests
# (e.g., when frontend and backend are reverse-proxied under one domain).
# Local development:
#   NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=

# Email alert signup is hidden unless backend email delivery is enabled too.
NEXT_PUBLIC_ENABLE_EMAIL_ALERTS=false

# Optional Google Analytics 4 Measurement ID (for example, G-XXXXXXXXXX).
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Optional Search Console HTML-tag verification token. A Domain property
# verified with a DNS TXT record is preferred and does not require this value.
GOOGLE_SITE_VERIFICATION=
