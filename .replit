run = "sh -lc '(cd backend && BACKEND_PORT=8000 npx tsx src/api/server.ts) & (cd frontend && npm run dev) & wait -n'"
modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

[env]
BACKEND_PORT = "8000"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "cloudrun"
build = ["bash", "/home/runner/workspace/build.sh"]
run = ["bash", "/home/runner/workspace/start.sh"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && BACKEND_URL=http://localhost:8080 npx next start --port 5000 --hostname 0.0.0.0"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && BACKEND_PORT=8080 npx tsx src/api/server.ts"
waitForPort = 8080
