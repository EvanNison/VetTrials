# Copy this file to .env and fill in real values.
# Never commit .env to git.

# ---- Required ----

# PostgreSQL connection string. Local example:
#   postgresql://postgres:postgres@localhost:5432/vettrials
DATABASE_URL=

# Anthropic API key for Claude extraction. Get one at https://console.anthropic.com
# A full scrape of 30 sources costs ~$0.50-$2.00 per run.
ANTHROPIC_API_KEY=

# ---- Optional ----

# How often the scheduled scraper runs, in hours. Default: 24.
SCRAPE_INTERVAL_HOURS=24

# Public URL of the frontend (used in CORS allow-list and email links).
FRONTEND_URL=http://localhost:3000

# Public canonical site URL used in the scraper User-Agent.
PUBLIC_SITE_URL=https://vettrials.org

# Public URL of this API (used in API responses and docs).
API_URL=http://localhost:8000

# Path to a Chromium binary for Playwright. Leave unset to use Playwright's bundled browser.
# CHROME_PATH=/usr/bin/chromium

# ---- Email alerts (optional, only needed if you enable subscriptions) ----

# Resend API key. Get one at https://resend.com
# RESEND_API_KEY=

# Email alert signup is disabled unless this is explicitly true.
ENABLE_EMAIL_ALERTS=false
